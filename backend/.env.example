# Smart Expense Tracker Environment Variables
# Duplicate this file as '.env' and adjust settings.

# Secret key for signing JWT tokens (Change this to a strong random hash in production)
JWT_SECRET=super_secret_key_change_me_in_production_1234567890

# Token life span in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Connection URI
# By default, falls back to SQLite file inside backend root directory.
# For PostgreSQL: postgresql://user:password@localhost:5432/expense_tracker
DATABASE_URL=sqlite:///./expense_tracker.db
